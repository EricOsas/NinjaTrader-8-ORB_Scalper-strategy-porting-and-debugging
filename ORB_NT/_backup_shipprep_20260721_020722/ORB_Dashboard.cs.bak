using System;
using System.Collections.Generic;
using NinjaTrader.Gui.Chart;
using NinjaTrader.NinjaScript.Strategies;
using SharpDX;
using SharpDX.Direct2D1;
using SharpDX.DirectWrite;

namespace NinjaTrader.NinjaScript.Strategies.ORB_NT
{
    public struct ORBDashState
    {
        // Account / Compliance
        public double CurrentBalance;
        public double DrawdownFloor;
        public bool FloorLocked;
        public double DistanceToFloor;
        public double ConsistencyPctOfTotal;
        public double EvalProfitTarget;
        public double EvalProfitProgress;
        public int TradingDaysCompleted;
        public double FastTradePct;
        public bool ConsistencyWarning;

        // Session
        public string ActiveSession;
        public string SessionPhase;
        public string NYClock;
        public string SessionCountdownLabel;
        public int SecsToNextPhase;
        public string CutoffText;      // live session cutoff ("NY · 01:22:20"), null/"--" = hide row
        public double RangeHigh;
        public double RangeLow;
        public bool Slot1Active;
        public bool Slot2Active;
        public string Slot2Mode;
        public string SlotsIntraday;   // "NY · London · Asian" (enabled intraday slots)
        public string SlotsHtf;        // "Daily · Weekly" (enabled HTF slots), "" = hide row

        // Trade
        public bool InTrade;
        public string TradeDir;
        public double EntryPrice;
        public double StopLoss;
        public double TakeProfit;
        public int ContractCount;
        public string ContractMode;
        public double LiveRR;
        public bool BEActive;
        public string BEDetail;

        // Instrument
        public string InstrumentName;
        public double TickSize;
        public double PointSize;    // custom point (MT5 parity) — range/distances shown in these
        public double PointValue;

        // News
        public bool NewsBlackoutActive;
        public string NextNewsEvent;
        public string NewsSourceMode;
    }

    //======================================================================
    // ORB_Dashboard — Liquid-Glass panel (Direct2D, drawn from OnRender).
    // Movable (drag the header) and collapsible (– / + button).
    //======================================================================
    public static class ORB_Dashboard
    {
        private class PanelState
        {
            public ORBDashState S;
            public bool HasState;
            public float OffX, OffY;          // drag offset from default anchor
            public bool Collapsed;
            public bool Dragging;
            public float DragDX, DragDY;
            public RectangleF PanelRect;      // last drawn rects (hit testing)
            public RectangleF HeaderRect;
            public RectangleF BtnRect;
        }

        private static readonly Dictionary<Strategy, PanelState> panels = new Dictionary<Strategy, PanelState>();
        private static readonly object sync = new object();

        private static PanelState Get(Strategy strategy)
        {
            PanelState p;
            if (!panels.TryGetValue(strategy, out p))
            {
                p = new PanelState();
                panels[strategy] = p;
            }
            return p;
        }

        public static void Publish(Strategy strategy, ORBDashState s)
        {
            lock (sync)
            {
                var p = Get(strategy);
                p.S = s;
                p.HasState = true;
            }
        }

        public static void Clear(Strategy strategy)
        {
            lock (sync) { panels.Remove(strategy); }
        }

        //──────────────────────────────────────────────────────────────────
        // Mouse interaction — called from the strategy's chart mouse hooks.
        // Coordinates are device pixels in chart-panel space.
        //──────────────────────────────────────────────────────────────────
        public static bool OnMouseDown(Strategy strategy, float x, float y)
        {
            lock (sync)
            {
                var p = Get(strategy);
                if (!p.HasState) return false;
                if (Contains(p.BtnRect, x, y))
                {
                    p.Collapsed = !p.Collapsed;
                    return true;
                }
                if (Contains(p.HeaderRect, x, y))
                {
                    p.Dragging = true;
                    p.DragDX = x - p.PanelRect.X;
                    p.DragDY = y - p.PanelRect.Y;
                    return true;
                }
                return false;
            }
        }

        public static bool OnMouseMove(Strategy strategy, float x, float y)
        {
            lock (sync)
            {
                var p = Get(strategy);
                if (!p.Dragging) return false;
                p.OffX += (x - p.DragDX) - p.PanelRect.X;
                p.OffY += (y - p.DragDY) - p.PanelRect.Y;
                return true;
            }
        }

        public static bool OnMouseUp(Strategy strategy)
        {
            lock (sync)
            {
                var p = Get(strategy);
                if (!p.Dragging) return false;
                p.Dragging = false;
                return true;
            }
        }

        private static bool Contains(RectangleF r, float x, float y)
            => x >= r.X && x <= r.X + r.Width && y >= r.Y && y <= r.Y + r.Height;

        // ── palette ──
        private static readonly Color4 GlassBase   = FromRgba(15, 19, 28, 0.94f);
        private static readonly Color4 GlassSheen  = FromRgba(255, 255, 255, 0.07f);
        private static readonly Color4 GlassSheen2 = FromRgba(255, 255, 255, 0.02f);
        private static readonly Color4 HairLine    = FromRgba(255, 255, 255, 0.22f);
        private static readonly Color4 InnerLine   = FromRgba(255, 255, 255, 0.07f);
        private static readonly Color4 TxtPrimary  = FromRgba(240, 244, 250, 0.96f);
        private static readonly Color4 TxtMuted    = FromRgba(165, 178, 200, 0.85f);
        private static readonly Color4 TxtFaint    = FromRgba(140, 152, 175, 0.65f);
        private static readonly Color4 AccentBlue  = FromRgba(95, 170, 255, 1.0f);
        private static readonly Color4 AccentGreen = FromRgba(88, 214, 141, 1.0f);
        private static readonly Color4 AccentRed   = FromRgba(255, 105, 97, 1.0f);
        private static readonly Color4 AccentGold  = FromRgba(230, 195, 120, 1.0f);
        private static readonly Color4 PillBg      = FromRgba(255, 255, 255, 0.10f);

        private static Color4 FromRgba(byte r, byte g, byte b, float a)
            => new Color4(r / 255f, g / 255f, b / 255f, a);

        private const float PanelW = 320f;
        private const float Pad = 14f;
        private const float Radius = 18f;
        private const float LineH = 19f;
        private const float SectionGap = 10f;
        private const float HeaderH = 60f;

        public static void Render(Strategy strategy, ChartControl chartControl, RenderTarget rt)
        {
            PanelState p;
            ORBDashState s;
            bool collapsed;
            float offX, offY;
            lock (sync)
            {
                p = Get(strategy);
                if (!p.HasState) return;
                s = p.S;
                collapsed = p.Collapsed;
                offX = p.OffX;
                offY = p.OffY;
            }

            bool hasCutoff = !string.IsNullOrEmpty(s.CutoffText) && s.CutoffText != "--";
            bool hasHtfRow = !string.IsNullOrEmpty(s.SlotsHtf);

            // ── dynamic height (clock lives in the header — no hero block) ──
            float height;
            if (collapsed)
            {
                height = HeaderH + 6f;
            }
            else
            {
                int bodyLines = 7                       // account
                              + 3                       // range H/L/size
                              + 1 + (hasHtfRow ? 1 : 0) // Intraday / HTF rows
                              + (hasCutoff ? 1 : 0)
                              + 1                       // countdown row
                              + (s.InTrade ? 4 : 1)
                              + 2;                      // footer
                height = HeaderH + bodyLines * LineH
                       + 4 * (SectionGap * 0.8f + SectionGap * 0.6f)
                       + Pad * 2 + 6f;
            }

            float left = (float)chartControl.CanvasRight - 12f - PanelW + offX;
            float top = 12f + offY;

            var panel = new RoundedRectangle
            {
                Rect = new RectangleF(left, top, PanelW, height),
                RadiusX = Radius,
                RadiusY = Radius
            };

            using (var dw = new SharpDX.DirectWrite.Factory())
            using (var baseBrush = new SolidColorBrush(rt, GlassBase))
            {
                rt.FillRoundedRectangle(panel, baseBrush);

                using (var sheenBrush = new LinearGradientBrush(rt,
                    new LinearGradientBrushProperties
                    {
                        StartPoint = new Vector2(left, top),
                        EndPoint = new Vector2(left, top + height * 0.5f)
                    },
                    new GradientStopCollection(rt, new[]
                    {
                        new GradientStop { Position = 0f, Color = GlassSheen },
                        new GradientStop { Position = 1f, Color = GlassSheen2 }
                    })))
                {
                    rt.FillRoundedRectangle(panel, sheenBrush);
                }

                using (var border = new SolidColorBrush(rt, HairLine))
                    rt.DrawRoundedRectangle(panel, border, 1.2f);

                using (var fontHead = new TextFormat(dw, "Segoe UI Semibold", FontWeight.SemiBold, FontStyle.Normal, 14f))
                using (var fontMono = new TextFormat(dw, "Consolas", FontWeight.Normal, FontStyle.Normal, 12.5f))
                using (var fontMonoB = new TextFormat(dw, "Consolas", FontWeight.Bold, FontStyle.Normal, 12.5f))
                using (var fontHero = new TextFormat(dw, "Segoe UI", FontWeight.Light, FontStyle.Normal, 26f))
                using (var fontSmall = new TextFormat(dw, "Segoe UI", FontWeight.Normal, FontStyle.Normal, 10.5f))
                {
                    float x = left + Pad;
                    float w = PanelW - Pad * 2;
                    float y = top + 10f;

                    // ── header ──────────────────────────────────────────────
                    //  ● ORB SCALPER                    NY TIME
                    //  [session · phase]               18:57:08
                    // Traffic-light collapse dot top-left (macOS style),
                    // clock block cleanly right-aligned with its own caption.
                    // Clock lives in the header so it survives collapse.

                    // collapse dot (traffic light): blue = expanded, gold = collapsed
                    var btn = new RectangleF(x, top + 12f, 14f, 14f);
                    using (var dotBrush = new SolidColorBrush(rt, collapsed ? AccentGold : AccentBlue))
                    {
                        var dot = new Ellipse(new Vector2(btn.X + 7f, btn.Y + 7f), 6f, 6f);
                        rt.FillEllipse(dot, dotBrush);
                    }

                    // title next to the dot
                    DrawText(rt, dw, "ORB SCALPER", fontHead, x + 22f, top + 8f, w - 130f, TxtPrimary);

                    // status pill under the title, aligned with it
                    Color4 pillText = s.InTrade ? AccentGreen
                                    : s.NewsBlackoutActive ? AccentRed
                                    : AccentBlue;
                    DrawPill(rt, dw, s.ActiveSession + " · " + s.SessionPhase, fontSmall, x + 22f, top + 32f, pillText);

                    // clock block, right-aligned: tiny caption over the time
                    DrawTextRight(rt, dw, "NY TIME", fontSmall, x, top + 8f, w, TxtFaint);
                    DrawTextRight(rt, dw, s.NYClock, fontHero, x, top + 20f, w, AccentBlue);

                    y = top + HeaderH;

                    lock (sync)
                    {
                        p.PanelRect = new RectangleF(left, top, PanelW, height);
                        p.HeaderRect = new RectangleF(left, top, PanelW, HeaderH);
                        // generous hit area around the small traffic-light dot
                        p.BtnRect = new RectangleF(btn.X - 5f, btn.Y - 5f, btn.Width + 10f, btn.Height + 10f);
                    }

                    if (collapsed) return;

                    // countdown + cutoff rows (shifted up into the old hero space)
                    y = Row(rt, dw, fontMono, fontMonoB, x, y, w,
                        s.SessionCountdownLabel, FormatCountdown(s.SecsToNextPhase), TxtPrimary);
                    if (hasCutoff)
                        y = Row(rt, dw, fontMono, fontMonoB, x, y, w, "Cutoff", s.CutoffText, TxtFaint);
                    y += SectionGap * 0.6f;

                    DrawDivider(rt, x, y, w); y += SectionGap * 0.8f;

                    // ── account ──
                    y = Row(rt, dw, fontMono, fontMonoB, x, y, w, "Balance", string.Format("{0:C0}", s.CurrentBalance), TxtPrimary);
                    y = Row(rt, dw, fontMono, fontMonoB, x, y, w, "Loss Limit",
                        string.Format("{0:C0}{1}", s.DrawdownFloor, s.FloorLocked ? "  🔒" : ""),
                        s.FloorLocked ? AccentGold : TxtMuted);
                    y = Row(rt, dw, fontMono, fontMonoB, x, y, w, "Buffer Left", string.Format("{0:C0}", s.DistanceToFloor),
                        s.DistanceToFloor < 500 ? AccentRed : AccentGreen);
                    y = Row(rt, dw, fontMono, fontMonoB, x, y, w, "Eval Profit",
                        string.Format("{0:+$0;-$0} of {1:C0}", s.EvalProfitProgress, s.EvalProfitTarget),
                        s.EvalProfitProgress >= 0 ? AccentGreen : AccentRed);
                    y = Row(rt, dw, fontMono, fontMonoB, x, y, w, "Traded Days", string.Format("{0} of 3 min", s.TradingDaysCompleted), TxtMuted);
                    y = Row(rt, dw, fontMono, fontMonoB, x, y, w, "Best-Day %",
                        string.Format("{0:F1}% (max 40){1}", s.ConsistencyPctOfTotal, s.ConsistencyWarning ? "  ⚠" : ""),
                        s.ConsistencyWarning ? AccentGold : TxtMuted);
                    y = Row(rt, dw, fontMono, fontMonoB, x, y, w, "Quick Trades",
                        string.Format("{0:F1}% <10s (max 50){1}", s.FastTradePct, s.FastTradePct > 45 ? "  ⚠" : ""),
                        s.FastTradePct > 45 ? AccentGold : TxtMuted);
                    y += SectionGap * 0.6f;

                    DrawDivider(rt, x, y, w); y += SectionGap * 0.8f;

                    // ── range ──
                    if (s.RangeHigh > 0 && s.RangeLow > 0 && s.RangeHigh > s.RangeLow)
                    {
                        double ptSz = s.PointSize > 0 ? s.PointSize : s.TickSize;
                        double pts = ptSz > 0 ? (s.RangeHigh - s.RangeLow) / ptSz : 0;
                        y = Row(rt, dw, fontMono, fontMonoB, x, y, w, "Range High", string.Format("{0:F2}", s.RangeHigh), AccentGreen);
                        y = Row(rt, dw, fontMono, fontMonoB, x, y, w, "Range Low", string.Format("{0:F2}", s.RangeLow), AccentRed);
                        y = Row(rt, dw, fontMono, fontMonoB, x, y, w, "Range Size",
                            string.Format("{0:F2}  ({1:F0} pts)", s.RangeHigh - s.RangeLow, pts), TxtMuted);
                    }
                    else
                    {
                        y = Row(rt, dw, fontMono, fontMonoB, x, y, w, "Range High", "forming…", TxtFaint);
                        y = Row(rt, dw, fontMono, fontMonoB, x, y, w, "Range Low", "forming…", TxtFaint);
                        y = Row(rt, dw, fontMono, fontMonoB, x, y, w, "Range Size", "--", TxtFaint);
                    }
                    y = Row(rt, dw, fontMono, fontMonoB, x, y, w, "Intraday",
                        string.IsNullOrEmpty(s.SlotsIntraday) ? "--" : s.SlotsIntraday, AccentBlue);
                    if (hasHtfRow)
                        y = Row(rt, dw, fontMono, fontMonoB, x, y, w, "HTF", s.SlotsHtf, AccentBlue);
                    y += SectionGap * 0.6f;

                    DrawDivider(rt, x, y, w); y += SectionGap * 0.8f;

                    // ── position ──
                    if (s.InTrade)
                    {
                        Color4 dirClr = s.TradeDir == "LONG" ? AccentGreen : AccentRed;
                        y = Row(rt, dw, fontMono, fontMonoB, x, y, w, "Position",
                            string.Format("{0}  ×{1} {2}", s.TradeDir, s.ContractCount, s.ContractMode), dirClr);
                        y = Row(rt, dw, fontMono, fontMonoB, x, y, w, "Entry → SL/TP",
                            string.Format("{0:F2} → {1:F2} / {2:F2}", s.EntryPrice, s.StopLoss, s.TakeProfit), TxtPrimary);
                        y = Row(rt, dw, fontMono, fontMonoB, x, y, w, "Live R", string.Format("{0:F2}R", s.LiveRR),
                            s.LiveRR >= 0 ? AccentGreen : AccentRed);
                        y = Row(rt, dw, fontMono, fontMonoB, x, y, w, "BE",
                            s.BEActive ? "ACTIVE " + s.BEDetail : "pending", s.BEActive ? AccentGold : TxtFaint);
                    }
                    else
                    {
                        y = Row(rt, dw, fontMono, fontMonoB, x, y, w, "Position", "flat", TxtFaint);
                    }
                    y += SectionGap * 0.6f;

                    DrawDivider(rt, x, y, w); y += SectionGap * 0.8f;

                    // ── footer ──
                    y = Row(rt, dw, fontMono, fontMonoB, x, y, w, s.InstrumentName,
                        string.Format("tick {0}  ·  pt {1}  ·  ${2:F0}/1.0", s.TickSize,
                            s.PointSize > 0 ? s.PointSize : s.TickSize, s.PointValue), TxtFaint);
                    y = Row(rt, dw, fontMono, fontMonoB, x, y, w,
                        s.NewsBlackoutActive ? "News ⛔" : "News",
                        Truncate(s.NextNewsEvent, 30), s.NewsBlackoutActive ? AccentRed : TxtMuted);
                }
            }
        }

        // ── helpers ──
        private static float Row(RenderTarget rt, SharpDX.DirectWrite.Factory dw,
            TextFormat label, TextFormat value, float x, float y, float w, string k, string v, Color4 vClr)
        {
            DrawText(rt, dw, k, label, x, y, w * 0.5f, TxtFaint);
            DrawTextRight(rt, dw, v, value, x, y, w, vClr);
            return y + LineH;
        }

        private static void DrawText(RenderTarget rt, SharpDX.DirectWrite.Factory dw,
            string text, TextFormat fmt, float x, float y, float w, Color4 clr)
        {
            if (string.IsNullOrEmpty(text)) return;
            using (var layout = new TextLayout(dw, text, fmt, w, LineH + 24f))
            using (var b = new SolidColorBrush(rt, clr))
                rt.DrawTextLayout(new Vector2(x, y), layout, b);
        }

        private static void DrawTextRight(RenderTarget rt, SharpDX.DirectWrite.Factory dw,
            string text, TextFormat fmt, float x, float y, float w, Color4 clr)
        {
            if (string.IsNullOrEmpty(text)) return;
            using (var layout = new TextLayout(dw, text, fmt, w, LineH + 24f))
            {
                layout.TextAlignment = TextAlignment.Trailing;
                using (var b = new SolidColorBrush(rt, clr))
                    rt.DrawTextLayout(new Vector2(x, y), layout, b);
            }
        }

        private static void DrawPill(RenderTarget rt, SharpDX.DirectWrite.Factory dw,
            string text, TextFormat fmt, float x, float y, Color4 textClr)
        {
            using (var layout = new TextLayout(dw, text, fmt, 240f, 16f))
            {
                float tw = layout.Metrics.Width;
                var pill = new RoundedRectangle
                {
                    Rect = new RectangleF(x, y, tw + 18f, 18f),
                    RadiusX = 9f,
                    RadiusY = 9f
                };
                using (var bg = new SolidColorBrush(rt, PillBg))
                    rt.FillRoundedRectangle(pill, bg);
                using (var b = new SolidColorBrush(rt, textClr))
                    rt.DrawTextLayout(new Vector2(x + 9f, y + 1.5f), layout, b);
            }
        }

        private static void DrawDivider(RenderTarget rt, float x, float y, float w)
        {
            using (var b = new SolidColorBrush(rt, InnerLine))
                rt.DrawLine(new Vector2(x, y), new Vector2(x + w, y), b, 1f);
        }

        private static string FormatCountdown(int totalSeconds)
        {
            if (totalSeconds <= 0) return "--:--:--";
            int h = totalSeconds / 3600, m = (totalSeconds % 3600) / 60, s = totalSeconds % 60;
            return string.Format("{0:D2}:{1:D2}:{2:D2}", h, m, s);
        }

        private static string Truncate(string s, int max)
            => string.IsNullOrEmpty(s) ? "--" : (s.Length <= max ? s : s.Substring(0, max - 1) + "…");
    }
}
