using System;
using System.Windows.Media;
using NinjaTrader.Gui;
using NinjaTrader.Gui.Chart;
using NinjaTrader.NinjaScript;
using NinjaTrader.NinjaScript.DrawingTools;
using NinjaTrader.NinjaScript.Strategies;

namespace NinjaTrader.NinjaScript.Strategies.ORB_NT
{
    // Visual language ported from ORB_Visuals.mqh:
    //   - Range box: filled rectangle, subtle per-slot color, NO visible
    //     border (outline = transparent), behind the candles.
    //   - Level lines: BOUNDED trend lines (never full-chart horizontals).
    //     The entry line runs from the level's formation to the precise
    //     moment price first touched it.
    //   - Trades: TradingView long/short-tool style — translucent risk box
    //     (entry↔SL, red) and reward box (entry↔TP, teal/green) spanning
    //     trigger → resolution (or → now while live). Trail = dotted line;
    //     the SL box is removed once trailing takes over.
    public static class ORB_Visuals
    {
        // MT5 .set palette (C'r,g,b' → Color)
        public static readonly Brush ClrRangeBoxNY     = MakeBrush(25, 35, 45);
        public static readonly Brush ClrRangeBoxLondon = MakeBrush(31, 50, 48);
        public static readonly Brush ClrRangeBoxAsian  = MakeBrush(44, 39, 57);
        public static readonly Brush ClrRangeBoxDaily  = MakeBrush(45, 38, 30);
        public static readonly Brush ClrRangeBoxWeekly = MakeBrush(36, 43, 56);
        public static readonly Brush ClrEntryLine      = MakeBrush(214, 218, 224);
        // Execution boxes — EXACT EA defaults: Clr_SL_Line = C'55,57,68',
        // Clr_TP_Line = C'22,55,120', Clr_Trailing_Stop = C'162,138,88'
        public static readonly Brush ClrSLBox          = MakeBrush(55, 57, 68);
        public static readonly Brush ClrTPBox          = MakeBrush(22, 55, 120);
        public static readonly Brush ClrTrailingStop   = MakeBrush(162, 138, 88);

        public static Brush MakeBrush(byte r, byte g, byte b)
        {
            var br = new SolidColorBrush(Color.FromRgb(r, g, b));
            br.Freeze();
            return br;
        }

        // Guard every Draw.* call: an anchor time before the chart's first
        // loaded bar (or an unset DateTime.MinValue slipping through after a
        // reinit) makes NT8's internal bar lookup throw "Sequence contains no
        // matching element" as an UNHANDLED dialog. Validate + swallow here.
        private static bool ValidTime(DateTime t) => t > new DateTime(2000, 1, 1);

        private static void Guard(Action draw)
        {
            try { draw(); } catch { /* never let a draw fault escape to the UI */ }
        }

        // Drawing tools are independent chart objects with their OWN z-order —
        // they ignore the strategy's ZOrder entirely, which is why they bled
        // through the dashboard. Pin every ORB object to the bottom of the
        // object stack: bars render first, then these, then the panel (the
        // strategy render pass sits at int.MaxValue).
        private static void Sink(NinjaTrader.NinjaScript.DrawingTools.DrawingTool dt)
        {
            try { if (dt != null && dt.ZOrder != 1) dt.ZOrder = 1; } catch { }
        }

        // Minimum right-edge span: entry+exit inside one high-TF candle reads
        // as a candlestick. Extend the right edge to >= 3 bars of the CHART's
        // own timeframe.
        public static DateTime MinSpanRight(Strategy strategy, DateTime trigTime, DateTime rightTime)
        {
            try
            {
                var bp = strategy.BarsPeriod;
                if (bp == null) return rightTime;
                double mins;
                switch (bp.BarsPeriodType)
                {
                    case NinjaTrader.Data.BarsPeriodType.Minute: mins = bp.Value; break;
                    case NinjaTrader.Data.BarsPeriodType.Second: mins = bp.Value / 60.0; break;
                    case NinjaTrader.Data.BarsPeriodType.Day: mins = bp.Value * 1440.0; break;
                    default: return rightTime; // tick/range/renko: leave as-is
                }
                DateTime minRight = trigTime.AddMinutes(3.0 * Math.Max(mins, 1.0 / 60.0));
                return rightTime < minRight ? minRight : rightTime;
            }
            catch { return rightTime; }
        }

        //----------------------------------------------------------------------
        // Filled range box — transparent outline, subtle fill, behind candles
        //----------------------------------------------------------------------
        public static void DrawRangeBox(Strategy strategy, string tag, DateTime startTime, DateTime endTime,
            double rangeHigh, double rangeLow, Brush fillBrush, int opacity = 35)
        {
            if (rangeHigh <= rangeLow) return;
            if (!ValidTime(startTime) || endTime <= startTime) return;
            Guard(() => Sink(Draw.Rectangle(strategy, tag, false, startTime, rangeHigh, endTime, rangeLow,
                Brushes.Transparent, fillBrush, opacity)));
        }

        //----------------------------------------------------------------------
        // Bounded line (never a full-chart horizontal)
        //----------------------------------------------------------------------
        public static void DrawBoundedLine(Strategy strategy, string tag, DateTime t1, double p1,
            DateTime t2, double p2, Brush brush, DashStyleHelper dash, int width)
        {
            if (!ValidTime(t1)) return;
            if (t2 <= t1) t2 = t1.AddMinutes(1);
            Guard(() => Sink(Draw.Line(strategy, tag, false, t1, p1, t2, p2, brush, dash, width)));
        }

        //----------------------------------------------------------------------
        // TradingView-style long/short trade tool.
        // MT5 parity (ORBCreateBorderBox): SL/TP boxes are BORDERED with a
        // width-2 outline in the EA's exact colors plus a light fill — the
        // outline keeps them visible at any timeframe/zoom (a fill-only box
        // washes out on higher TFs).
        //   tagBase        unique per trade
        //   levelPx/levelTime  the range level and when it formed (entry line
        //                  runs levelTime → trigTime = first touch)
        //   rightTime      exit time when resolved, "now" while live
        //   trailing       true → SL box removed, dotted trail line at vSL
        //   synthetic      dashed entry line + slightly lighter fill
        //----------------------------------------------------------------------
        public static void DrawTradeTool(Strategy strategy, string tagBase, bool isLong,
            double entryPx, double slPx, double tpPx,
            double levelPx, DateTime levelTime, DateTime trigTime, DateTime rightTime,
            bool trailing, DateTime trailStartTime, bool synthetic)
        {
            if (!ValidTime(trigTime)) return;
            if (!ValidTime(levelTime)) levelTime = trigTime;
            if (rightTime <= trigTime) rightTime = trigTime.AddMinutes(1);

            // Timeframe-aware minimum span: boxes cover >= 3 chart bars so a
            // short scalp doesn't collapse into a candlestick on higher TFs.
            // Left anchors stay tick-exact; only the boxes' right edge pads.
            DateTime boxRight = MinSpanRight(strategy, trigTime, rightTime);

            int fillOpacity = synthetic ? 25 : 40;

            // Entry line: level formation → the tick that first touched it
            DrawBoundedLine(strategy, tagBase + "_ENT", levelTime, levelPx, trigTime, levelPx,
                ClrEntryLine, synthetic ? DashStyleHelper.Dash : DashStyleHelper.Solid, 2);

            // Risk box: entry ↔ SL, EA color C'55,57,68', bordered (skipped
            // once trailing owns the stop — MT5 deletes it then too)
            if (!trailing)
            {
                Guard(() =>
                {
                    var slRect = Draw.Rectangle(strategy, tagBase + "_SL", false, trigTime, entryPx, boxRight, slPx,
                        ClrSLBox, ClrSLBox, fillOpacity);
                    if (slRect != null && slRect.OutlineStroke != null)
                        slRect.OutlineStroke.Width = 2;
                    Sink(slRect);
                });
            }
            else
            {
                strategy.RemoveDrawObject(tagBase + "_SL");
            }

            // Reward box: entry ↔ TP, EA color C'22,55,120', bordered
            if (tpPx > 0)
            {
                Guard(() =>
                {
                    var tpRect = Draw.Rectangle(strategy, tagBase + "_TP", false, trigTime, entryPx, boxRight, tpPx,
                        ClrTPBox, ClrTPBox, fillOpacity);
                    if (tpRect != null && tpRect.OutlineStroke != null)
                        tpRect.OutlineStroke.Width = 2;
                    Sink(tpRect);
                });
            }

            // Trail line: EA color C'162,138,88', dotted, trail start → right edge
            if (trailing && ValidTime(trailStartTime))
            {
                DateTime tl = trailStartTime >= trigTime ? trailStartTime : trigTime;
                DrawBoundedLine(strategy, tagBase + "_TRAIL", tl, slPx, boxRight, slPx,
                    ClrTrailingStop, DashStyleHelper.Dot, 2);
            }
            else
            {
                strategy.RemoveDrawObject(tagBase + "_TRAIL");
            }
        }

        public static void RemoveTradeTool(Strategy strategy, string tagBase)
        {
            strategy.RemoveDrawObject(tagBase + "_ENT");
            strategy.RemoveDrawObject(tagBase + "_SL");
            strategy.RemoveDrawObject(tagBase + "_TP");
            strategy.RemoveDrawObject(tagBase + "_TRAIL");
        }

        //----------------------------------------------------------------------
        // Pending level line: dashed, range end → now (updated per pulse)
        //----------------------------------------------------------------------
        public static void DrawPendingLine(Strategy strategy, string tag, double price,
            DateTime fromTime, DateTime toTime)
        {
            DrawBoundedLine(strategy, tag, fromTime, price, toTime, price,
                ClrEntryLine, DashStyleHelper.Dash, 1);
        }

        public static void RemoveObject(Strategy strategy, string tag)
        {
            strategy.RemoveDrawObject(tag);
        }

        //----------------------------------------------------------------------
        // Clear all visuals for one slot prefix — prefix-scan of the chart's
        // draw objects, so EVERY tag under the slot goes (including legacy
        // tags from older builds: arrows, labels, old line names).
        //----------------------------------------------------------------------
        public static void ClearAllVisuals(Strategy strategy, string slotPrefix)
        {
            try
            {
                var toRemove = new System.Collections.Generic.List<string>();
                foreach (var obj in strategy.DrawObjects)
                {
                    if (obj?.Tag != null && obj.Tag.StartsWith(slotPrefix + "_"))
                        toRemove.Add(obj.Tag);
                }
                foreach (string tag in toRemove)
                    strategy.RemoveDrawObject(tag);
            }
            catch { }
        }

        //----------------------------------------------------------------------
        // Full purge: every ORB-owned draw object regardless of build version.
        // Called once at Realtime start so leftovers from older strategy
        // builds (arrows/diamonds/labels from July 16 etc.) never linger.
        //----------------------------------------------------------------------
        private static readonly string[] OrbTagPrefixes = {
            "S0_", "S1_", "S2_", "S3_", "S4_", "S5_",
            "RangeBox_", "RangeHigh_", "RangeLow_", "LT", "ORB_OCO_", "ORB_S"
        };

        public static void PurgeAllOrbObjects(Strategy strategy)
        {
            try
            {
                // 1. Everything this instance created
                strategy.RemoveDrawObjects();
            }
            catch { }
            try
            {
                // 2. This instance's tagged leftovers (belt & braces)
                var toRemove = new System.Collections.Generic.List<string>();
                foreach (var obj in strategy.DrawObjects)
                {
                    string tag = obj?.Tag;
                    if (tag == null) continue;
                    foreach (string p in OrbTagPrefixes)
                    {
                        if (tag.StartsWith(p)) { toRemove.Add(tag); break; }
                    }
                }
                foreach (string tag in toRemove)
                    strategy.RemoveDrawObject(tag);
            }
            catch { }
            try
            {
                // 3. CHART-LEVEL orphans: objects left by PREVIOUS strategy
                //    instances survive in the workspace and are invisible to
                //    this instance's DrawObjects — the "July 16 arrows".
                //    Remove them straight off the ChartControl (UI thread).
                var cc = strategy.ChartControl;
                if (cc != null)
                {
                    cc.Dispatcher.InvokeAsync(() =>
                    {
                        try
                        {
                            var orphans = new System.Collections.Generic.List<NinjaTrader.NinjaScript.DrawingTools.DrawingTool>();
                            foreach (var co in cc.ChartObjects)
                            {
                                var dt = co as NinjaTrader.NinjaScript.DrawingTools.DrawingTool;
                                string tag = dt?.Tag;
                                if (tag == null) continue;
                                foreach (string p in OrbTagPrefixes)
                                {
                                    if (tag.StartsWith(p)) { orphans.Add(dt); break; }
                                }
                            }
                            foreach (var dt in orphans)
                                cc.ChartObjects.Remove(dt);
                            if (orphans.Count > 0) cc.InvalidateVisual();
                        }
                        catch { }
                    });
                }
            }
            catch { }
        }
    }
}
